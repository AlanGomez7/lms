<div class="container-fluid px-3">
  <form action="/books/search" method="get" class="row g-2">
    <div class="col-12 col-md-9">
      <input
        type="text"
        name="data"
        class="form-control form-control-lg"
        id="search-input"
        placeholder="Search your favorite books by Name or ISBN"
      />
    </div>
    <div class="col-12 col-md-3 d-grid">
      <button
        type="submit"
        class="btn btn-primary btn-lg"
        id="search-btn"
      >
        Search Books
      </button>
    </div>
  </form>
</div>